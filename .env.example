# PSYNAPSYS E2E — Environment Variables
# Copy this file to .env.local and fill in values

# -------------------------------------------------------
# Application URLs
# -------------------------------------------------------
BASE_URL=https://test.qa.app.psynap-sys.com
# API server is on a separate subdomain from the frontend app
API_URL=https://qa.api.psynap-sys.com/api

# -------------------------------------------------------
# Therapist Portal Credentials (provider/staff)
# Login URL: https://test.qa.app.psynap-sys.com/auth/login
# Has access to: patients, appointments, billing, intake forms, notes
# -------------------------------------------------------
TEST_THERAPIST_EMAIL=your-therapist@example.com
TEST_THERAPIST_PASSWORD=YourTherapistPassword

# -------------------------------------------------------
# Client Portal Credentials (patient)
# Login URL: https://test.qa.app.psynap-sys.com/auth/login
# Has access to: own appointments, intake forms, messages
# -------------------------------------------------------
TEST_CLIENT_EMAIL=your-client@example.com
TEST_CLIENT_PASSWORD=YourClientPassword

# -------------------------------------------------------
# CI Environment
# -------------------------------------------------------
# Set to "true" in CI to enable retry + JUnit reporting
CI=

# -------------------------------------------------------
# Optional: Playwright settings
# -------------------------------------------------------
# Number of parallel workers (default: 50% of CPUs in CI)
# PLAYWRIGHT_WORKERS=4

# Headless mode (default: true)
# PLAYWRIGHT_HEADLESS=true
